rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Images uploaded by users
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024  // 5 MB max
                   && request.resource.contentType.matches('image/.*');
    }

    // Audio files
    match /audio/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 20 * 1024 * 1024  // 20 MB max
                   && request.resource.contentType.matches('audio/.*');
    }

    // PDF / other files
    match /files/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 10 * 1024 * 1024;  // 10 MB max
    }
  }
}
